{
  "compilerOptions": {
    "target": "ES2022",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,

    "skipLibCheck": true,

    "rootDir": "./src",

    "outDir": "./dist",

    "types": [
      "node"
    ],

    "esModuleInterop": true,

    "forceConsistentCasingInFileNames": true
  },

  "include": [
    "src/**/*"
  ],

  "exclude": [
    "node_modules",
    "dist",
    "tests"
  ]
}